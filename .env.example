# Copy to .env for local Docker use. Never commit the real file.
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=weight_path
APP_PASSWORD=replace-with-a-unique-password
SESSION_SECRET=replace-with-a-long-random-string
# Use the IANA zone of the person recording check-ins. Defaults to UTC when omitted.
APP_TIME_ZONE=America/Edmonton
WEBAPP_PORT=8080
